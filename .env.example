# AidLockIn environment — copy to .env.local and fill in.
#
# Pick ONE backend. lib/db.ts uses Aurora DSQL when PGHOST or DSQL_ENDPOINT is
# set, and otherwise falls back to DATABASE_URL (plain Postgres).

# ── Option A: Amazon Aurora DSQL (the hackathon target) ─────────────────────
# Provision a DSQL cluster, then point these at it. Auth is IAM — the
# connector signs short-lived tokens from your AWS credential chain
# (`aws configure`, env vars, or an instance role), so there is no DB password.
# DSQL_ENDPOINT=<cluster-id>.dsql.<region>.on.aws
# PGUSER=admin
# PGDATABASE=postgres
# PGPORT=5432
# AWS_REGION=us-east-1
# Local AWS creds (only if not using `aws configure` / a shared profile):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── Option B: plain Postgres 14+ (fast local dev / CI) ──────────────────────
# A local Postgres, Docker, or a free Neon database works. The OCC race story
# is only fully real on DSQL (see lib/db.ts), but the rest of the app and the
# test suite run identically here.
# DATABASE_URL=postgresql://user:password@localhost:5432/yourdb

# ── Option C: zero-database demo mode ───────────────────────────────────────
# Set DEMO_MODE=1 and the app runs against an in-process PGlite (WASM Postgres)
# that auto-migrates and auto-seeds on first request — no Docker, no DATABASE_URL,
# no AWS. Every screen is clickable out of the box. Data is in-memory and resets
# on restart. DEMO_MODE overrides the options above when set.
#   DEMO_MODE=1 npm run dev
# DEMO_MODE=1

# ── Tests ───────────────────────────────────────────────────────────────────
# tests/setup.ts also reads .env.test if present — point it at a THROWAWAY
# migrated database so the suite can create and tear down its own rows.
